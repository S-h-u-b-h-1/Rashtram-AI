PORT=5001
CLIENT_URL=http://localhost:3000

DATABASE_URL=postgresql://user:password@host/database?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret

GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_PROVIDER=local

PINECONE_API_KEY=replace-with-pinecone-api-key
PINECONE_INDEX_NAME=rashtram-bills
PINECONE_ACT_INDEX_NAME=rashtram-acts
# Optional. If omitted, domain-separated operational tokens are derived from
# existing server-only secrets. The underlying secrets are never sent.
CATALOG_INGESTION_SECRET=
PINECONE_NAMESPACE=local-hash-v1
